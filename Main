-- If splib failed to load (fallback), provide simple keybind toggles so features remain testable.
if usedFallback then
  print("splib failed to load — using keybind fallbacks: RightShift=Walkspeed, RightControl=JumpPower")
  UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.Keyboard then
      if input.KeyCode == Enum.KeyCode.RightShift then
        WalkspeedEnabled = not WalkspeedEnabled
        updateWalkspeed()
        print("Walkspeed toggled (fallback):", WalkspeedEnabled)
      elseif input.KeyCode == Enum.KeyCode.RightControl then
        JumpPowerEnabled = not JumpPowerEnabled
        updateJumpPower()
        print("JumpPower toggled (fallback):", JumpPowerEnabled)
      end
    end
  end)
end

local function sanitizeNumberText(text)
  return tostring(text or ""):gsub("%D", "")
end

local function findPlayerMoneyStat()
  local moneyNames = {"Money", "Cash", "Coins", "Currency", "Balance", "Wallet"}
  local function matchesName(obj)
    for _, name in ipairs(moneyNames) do
      if obj.Name == name then
        return true
      end
    end
    return false
  end

  local function search(root)
    if not root or not root.GetDescendants then
      return nil
    end
    for _, obj in ipairs(root:GetDescendants()) do
      if (obj:IsA("IntValue") or obj:IsA("NumberValue")) and matchesName(obj) then
        return obj
      end
    end
    return nil
  end

  if LocalPlayer then
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats then
      local stat = search(leaderstats)
      if stat then
        return stat
      end
    end
    return search(LocalPlayer)
  end
  return nil
end

local function setPlayerMoney(amount)
  amount = tonumber(amount)
  if not amount then
    return false
  end
  local stat = findPlayerMoneyStat()
  if not stat then
    return false
  end
  if stat:IsA("IntValue") then
    stat.Value = math.floor(amount)
  else
    stat.Value = amount
  end
  return true
end

