local moneyTextBox = testTab:AddTextbox({
  Name = "Money Amount",
  Desc = "Type a number and press Enter to change your money.",
  PlaceholderText = "Numbers only",
  Default = "",
  Flag = "TestMoneyAmount",
  Callback = function(Value)
    local amount = sanitizeNumberText(Value)
    if amount == "" then
      return
    end
    setPlayerMoney(amount)
  end
})

if moneyTextBox then
  moneyTextBox.OnChanging = function(text)
    return sanitizeNumberText(text)
  end
end

